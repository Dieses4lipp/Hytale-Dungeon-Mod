Group #StatsSection {
  LayoutMode: CenterMiddle;
  Anchor: (Full: 0);
  Background: #000000(0.0);

  Group #MainPanel {
    LayoutMode: Left;
    Anchor: (Width: 1060, Height: 720);
    Background: #0d1117(0.97);
    Padding: (Horizontal: 20, Vertical: 24);

    Group #LeftPanel {
      LayoutMode: Top;
      Anchor: (Width: 640, Height: 672);

      Label { 
        Text: "YOUR INVENTORY"; 
        Style: (FontSize: 22, TextColor: #f5c518, RenderBold: true, HorizontalAlignment: Center); 
        Anchor: (Width: 640, Height: 30); 
      }
      
      Group { Anchor: (Height: 12); }

      Group #InvRow1 { LayoutMode: Left; Anchor: (Width: 640, Height: 64);
        Group #Slot1  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot2  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot3  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot4  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot5  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot6  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot7  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot8  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot9  { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); }
      }
      Group { Anchor: (Height: 8); }
      Group #InvRow2 { LayoutMode: Left; Anchor: (Width: 640, Height: 64);
        Group #Slot10 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot11 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot12 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot13 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot14 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot15 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot16 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot17 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot18 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); }
      }
      Group { Anchor: (Height: 8); }
      Group #InvRow3 { LayoutMode: Left; Anchor: (Width: 640, Height: 64);
        Group #Slot19 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot20 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot21 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot22 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot23 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot24 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot25 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot26 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot27 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); }
      }
      Group { Anchor: (Height: 8); }
      Group #InvRow4 { LayoutMode: Left; Anchor: (Width: 640, Height: 64);
        Group #Slot28 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot29 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot30 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot31 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot32 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot33 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot34 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot35 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot36 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); }
      }

      Group { Anchor: (Height: 16); }
      Group { Anchor: (Width: 640, Height: 2); Background: #2a3040; }
      Group { Anchor: (Height: 16); }

      Group #HotbarRow { LayoutMode: Left; Anchor: (Width: 640, Height: 64);
        Group #Slot37 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot38 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot39 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot40 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot41 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot42 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot43 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot44 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); } Group { Anchor: (Width: 8); }
        Group #Slot45 { Anchor: (Width: 64, Height: 64); Background: #30435f(0.7); }
      }

      Group { FlexWeight: 1; }

      // --- DEPOSIT BUTTONS ---
      Label { 
        Text: "DEPOSIT SELECTED ITEM:"; 
        Style: (FontSize: 13, TextColor: #8899aa, HorizontalAlignment: Center); 
        Anchor: (Width: 640, Height: 22); 
      }
      Group { Anchor: (Height: 6); }
      
      Group #StashSlotRow {
        LayoutMode: CenterMiddle;
        Anchor: (Width: 640, Height: 52);
        Group #StashSlotWrapper {
          Anchor: (Width: 52, Height: 52);
          Group #StashTargetSlot { Anchor: (Full: 0); Background: #30435f(0.6); }
          TextButton #StashDepositBtn { Anchor: (Full: 0); Text: ""; Background: #000000(0.0); Style: (Hovered: (Background: #254a7588)); }
        }
      }

      Group { Anchor: (Height: 8); }
      TextButton #QuickDepositAllBtn { 
        Anchor: (Width: 310, Height: 44); 
        Text: "DEPOSIT ALL TO STASH"; 
        Padding: (Horizontal: 12); 
        Style: (
          Default: (Background: #1a3a5c, LabelStyle: (RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)), 
          Hovered: (Background: #254a75, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)), 
          Pressed: (Background: #0f151e, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))
        ); 
      }
      Group { Anchor: (Height: 8); }
      TextButton #QuickDepositBtn { 
        Anchor: (Width: 310, Height: 44); 
        Text: "DEPOSIT "; 
        Padding: (Horizontal: 12); 
        Style: (
          Default: (Background: #1a3a5c, LabelStyle: (RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)), 
          Hovered: (Background: #254a75, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)), 
          Pressed: (Background: #0f151e, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))
        ); 
      }
    }

    // ==========================================
    // VERTICAL DIVIDER
    // ==========================================
    Group { Anchor: (Width: 20); }
    Group { Anchor: (Width: 2, Height: 672); Background: #2a3040; }
    Group { Anchor: (Width: 20); }

    // ==========================================
    // RIGHT PANEL: STATS & CONTINUE
    // ==========================================
    Group #RightPanel {
      LayoutMode: Top;
      Anchor: (Width: 338, Height: 672);

      Label { 
        Text: "DUNGEON RECAP"; 
        Style: (FontSize: 32, TextColor: #5bc8f5, RenderBold: true, HorizontalAlignment: Center); 
        Anchor: (Full: 0, Height: 50); 
      }

      Label { 
        Text: "Boss Defeated!"; 
        Style: (FontSize: 18, TextColor: #00FF00, HorizontalAlignment: Center);
        Anchor: (Full: 0, Height: 30);
      }

      Group { Anchor: (Height: 24); }

      Group #TimeBox {
        LayoutMode: CenterMiddle;
        Anchor: (Width: 338, Height: 50);
        Background: #30435f(0.3);
        Label #TimeLabel { 
          Text: "TIME NEEDED: --:--"; 
          Style: (FontSize: 18, TextColor: #ffffff, HorizontalAlignment: Center); 
        }
      }

      Group { Anchor: (Height: 8); }

      Group #GoldBox {
        LayoutMode: CenterMiddle;
        Anchor: (Width: 338, Height: 50);
        Background: #f5c518(0.1);
        Label #GoldValueLabel { 
          Text: "GOLD EARNED: 0"; 
          Style: (FontSize: 18, TextColor: #f5c518, HorizontalAlignment: Center); 
        }
      }

      Group { Anchor: (Height: 8); }

      Group #StatsBox {
        LayoutMode: CenterMiddle;
        Anchor: (Width: 338, Height: 50);
        Background: #30435f(0.3); 
        Label #StatsLabel { 
          Text: "ENEMIES KILLED: 0"; 
          Style: (FontSize: 16, TextColor: #8899aa, HorizontalAlignment: Center); 
        }
      }

      Group { Anchor: (Height: 8); }

      Group #LevelBox {
        LayoutMode: CenterMiddle;
        Anchor: (Width: 338, Height: 50);
        Background: #30435f(0.3); 
        Label #LevelLabel { 
          Text: "LEVEL: 0"; 
          Style: (FontSize: 18, TextColor: #aa88ff, HorizontalAlignment: Center, RenderBold: true); 
        }
      }

      Group { FlexWeight: 1; } // Pushes the continue button to the bottom

      TextButton #CloseBtn { 
        Anchor: (Width: 338, Height: 60); 
        Text: "CONTINUE TO HUB"; 
        Padding: (Horizontal: 12); 
        Style: (
          Default: (Background: #1a3a5c, LabelStyle: (RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)), 
          Hovered: (Background: #254a75, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)), 
          Pressed: (Background: #0f151e, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))
        ); 
      }
    }
  }
}