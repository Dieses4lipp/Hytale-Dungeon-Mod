Group {
  LayoutMode: Top;
  Anchor: (Full: 0);
  Background: #000000(0.0);

  Group #TopNav {
    Anchor: (Full: 0, Height: 100);
    LayoutMode: Left;
    Background: #0d1117;
    Padding: (Horizontal: 40, Vertical: 18);

    TextButton #PlayBtn { Anchor: (Width: 140, Height: 64); Text: "PLAY"; Padding: (Horizontal: 14); Background: #1c2333; Style: (Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); }
    Group { Anchor: (Width: 8); }
    TextButton #StashBtn { Anchor: (Width: 140, Height: 64); Text: "INVENTORY"; Padding: (Horizontal: 14); Background: #1c3a5c; Style: (Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)), Hovered: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)), Pressed: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); }
    Group { Anchor: (Width: 8); }
    TextButton #CharacterBtn { Anchor: (Width: 180, Height: 64); Text: "CHARACTER"; Padding: (Horizontal: 14); Background: #1c2333; Style: (Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); }
    Group { Anchor: (Width: 8); }
    TextButton #MarketBtn { Anchor: (Width: 140, Height: 64); Text: "MARKET"; Padding: (Horizontal: 14); Background: #1c2333; Style: (Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); }
    Group { Anchor: (Width: 8); }
    TextButton #LeaderboardBtn { Anchor: (Width: 200, Height: 64); Text: "LEADERBOARDS"; Padding: (Horizontal: 14); Background: #1c2333; Style: (Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); }
  }

  Group #NavSpacer { Anchor: (Full: 0, Height: 18); Background: #060809; }

  Group #ContentRow {
    FlexWeight: 1;
    LayoutMode: Left;

    Group #EquipmentPanel {
      FlexWeight: 1;
      LayoutMode: Left;

      Group #ArmorCol {
        Anchor: (Width: 320); LayoutMode: Top; Padding: (Top: 128, Left: 40);
        Group #EquipHead { Anchor: (Width: 128, Height: 128); TextButton #EquipHeadBtn { Anchor: (Full: 0); Text: "Head"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
        Group { Anchor: (Height: 16); }
        Group #EquipChest { Anchor: (Width: 128, Height: 128); TextButton #EquipChestBtn { Anchor: (Full: 0); Text: "Chest"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
        Group { Anchor: (Height: 16); }
        Group #EquipGloves { Anchor: (Width: 128, Height: 128); TextButton #EquipGlovesBtn { Anchor: (Full: 0); Text: "Gloves"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
        Group { Anchor: (Height: 16); }
        Group #EquipPants { Anchor: (Width: 128, Height: 128); TextButton #EquipPantsBtn { Anchor: (Full: 0); Text: "Pants"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
      }

      Group #CharacterSpace {
        Anchor: (Width: 350);
      }

      Group #WeaponCol {
        LayoutMode: Top; Padding: (Top: 128, Left: 0);
        Group #EquipWeapon { Anchor: (Width: 128, Height: 128); TextButton #EquipWeaponBtn { Anchor: (Full: 0); Text: "Weap"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
        Group { Anchor: (Height: 16); }
        Group #EquipShield { Anchor: (Width: 128, Height: 128); TextButton #EquipShieldBtn { Anchor: (Full: 0); Text: "Shld"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
        Group { Anchor: (Height: 16); }
        Group #EquipHeal { Anchor: (Width: 128, Height: 128); TextButton #EquipHealBtn { Anchor: (Full: 0); Text: "Heal"; Background: #141c28; Style: (Hovered: (Background: #254a75), Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))); } }
      }
      Group { FlexWeight: 1; }
    }

