      Group #HotbarRow { LayoutMode: Left; Anchor: (Width: 560, Height: 56);
        Group #InvSlot37 { Anchor: (Width: 56, Height: 56); Background: #3a5080(0.7); } Group { Anchor: (Width: 7); }
