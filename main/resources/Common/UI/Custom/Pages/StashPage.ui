      Group { FlexWeight: 1; }

      Label #SelectionLabel {
        Text: "Click an item to select, then click a stash slot";
        Style: (FontSize: 13, TextColor: #8899aa, HorizontalAlignment: Center);
        Anchor: (Width: 560, Height: 22);
      }
      Group { Anchor: (Height: 8); }
      TextButton #DepositAllBtn {
        Anchor: (Width: 560, Height: 44);
        Text: "DEPOSIT ALL TO STASH";
        Padding: (Horizontal: 12);
        Style: (
          Default: (Background: #1a3a5c, LabelStyle: (RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #254a75, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #0f151e, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))
        );
      }
      Group { Anchor: (Height: 8); }
      TextButton #CloseBtn {
        Anchor: (Width: 560, Height: 44);
        Text: "CLOSE";
        Padding: (Horizontal: 12);
        Style: (
          Default: (Background: #1c2333, LabelStyle: (RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
          Hovered: (Background: #2a344d, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center)),
          Pressed: (Background: #0f151e, LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center))
        );
      }
