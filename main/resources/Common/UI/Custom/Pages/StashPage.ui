Group {
  LayoutMode: CenterMiddle;
  Anchor: (Full: 0);
  Background: #000000(0.0);

  Group #MainPanel {
    LayoutMode: Left;
    Anchor: (Width: 1200, Height: 760);
    Background: #0d1117(0.97);
    Padding: (Horizontal: 20, Vertical: 24);

    Group #LeftPanel {
      LayoutMode: Top;
      Anchor: (Width: 560, Height: 712);

      Label {
